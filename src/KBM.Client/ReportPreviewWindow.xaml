<Window x:Class="KBM.Client.ReportPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Anteprima di stampa" Height="760" Width="1040"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Border Background="White" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="4">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="22" ShadowDepth="3"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header band -->
            <Border Grid.Row="0" Padding="16,11" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{StaticResource C.Primary600}" Offset="0"/>
                        <GradientStop Color="{StaticResource C.Primary700}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                            Width="26" Height="26" Padding="0" Background="Transparent" BorderThickness="0"
                            Foreground="White" Cursor="Hand" Click="Close_Click" ToolTip="Chiudi (ESC)"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="White"
                                   Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Anteprima di stampa" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock x:Name="TitleText" FontSize="11" Foreground="#DCE6F2"/>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Toolbar -->
            <Border Grid.Row="1" Background="{StaticResource Brush.SurfaceAlt}"
                    BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <Button Height="32" Padding="12,0" Click="Print_Click" Style="{StaticResource KbmButton}"
                            ToolTip="Stampa (Ctrl+P)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,7,0"/>
                            <TextBlock Text="Stampa"/>
                        </StackPanel>
                    </Button>
                    <Border Width="1" Height="22" Background="{StaticResource Brush.Border}" Margin="12,0"/>
                    <TextBlock Text="Esporta:" VerticalAlignment="Center" FontSize="12"
                               Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,8,0"/>
                    <Button Content="PDF" Height="32" Padding="14,0" Margin="0,0,6,0" Click="ExportPdf_Click"/>
                    <Button Content="Excel" Height="32" Padding="14,0" Margin="0,0,6,0" Click="ExportExcel_Click"/>
                    <Button Content="CSV" Height="32" Padding="14,0" Margin="0,0,6,0" Click="ExportCsv_Click"/>
                    <Button Content="HTML" Height="32" Padding="14,0" Click="ExportHtml_Click"/>
                </StackPanel>
            </Border>

            <FlowDocumentReader x:Name="Reader" Grid.Row="2" Background="#ECEFF3"
                                ViewingMode="Page" IsFindEnabled="True"/>
        </Grid>
    </Border>
</Window>
