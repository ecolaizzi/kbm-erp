<Window x:Class="KBM.Client.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Fluent="urn:fluent-ribbon"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="KBM ERP — Kever Business Manager" Height="840" Width="1340"
        MinHeight="660" MinWidth="1120" WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize" WindowState="Maximized"
        Background="{StaticResource Brush.AppBg}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38" ResizeBorderThickness="6" CornerRadius="0"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- ===================== COMMAND BAR (ricerca + sessione) ===================== -->
        <Border Grid.Row="1" Height="48" Background="White"
                BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1">
            <DockPanel Margin="14,0">
                <!-- Sessione: azienda corrente (fissata al login) + logout -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource Brush.PrimarySelect}" CornerRadius="3" Padding="9,4"
                            VerticalAlignment="Center"
                            ToolTip="Azienda di lavoro fissata al login. Per cambiarla, esci e accedi di nuovo.">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE825;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{StaticResource Brush.PrimaryActive}" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="CompanyText" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.PrimaryActive}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Width="1" Height="22" Background="{StaticResource Brush.Border}" Margin="14,0"/>
                    <Button Height="30" Padding="12,0" Click="Logout_Click" ToolTip="Esci dalla sessione">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="#DC2626" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Esci" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Ricerca globale (stile Mago4) -->
                <Grid Width="420" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBox x:Name="GlobalSearch" Height="32" Padding="32,0,10,0"
                             Tag="Cerca utenti, aziende, ruoli..." TextChanged="GlobalSearch_TextChanged"/>
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{StaticResource Brush.TextMuted}" IsHitTestVisible="False"
                               Margin="11,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <Popup x:Name="SearchPopup" PlacementTarget="{Binding ElementName=GlobalSearch}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True" Width="420">
                        <Border Background="White" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                CornerRadius="3" Margin="0,4,0,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="14" ShadowDepth="2"/>
                            </Border.Effect>
                            <StackPanel>
                                <ListBox x:Name="SearchResults" BorderThickness="0" MaxHeight="380"
                                         SelectionChanged="SearchResults_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="4,6">
                                                <Border DockPanel.Dock="Left" CornerRadius="3" Padding="6,2"
                                                        Background="{StaticResource Brush.PrimarySelect}"
                                                        VerticalAlignment="Center" Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding ModuleLabel}" FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource Brush.PrimaryActive}"/>
                                                </Border>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="13"
                                                               Foreground="{StaticResource Brush.Text}"/>
                                                    <TextBlock Text="{Binding Subtitle}" FontSize="11"
                                                               Foreground="{StaticResource Brush.TextSecondary}"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock x:Name="SearchEmpty" Text="Nessun risultato" FontSize="12"
                                           Foreground="{StaticResource Brush.TextMuted}" Margin="12,10"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </DockPanel>
        </Border>

        <!-- ===================== BARRA SUPERIORE CORPORATE (title bar custom) ===================== -->
        <Border Grid.Row="0" Height="38">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{StaticResource C.Primary600}" Offset="0"/>
                    <GradientStop Color="{StaticResource C.Primary700}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Resources>
                <Style x:Key="WinBtn" TargetType="Button">
                    <Setter Property="Width" Value="46"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#33FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style x:Key="WinCloseBtn" TargetType="Button" BasedOn="{StaticResource WinBtn}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#E81123"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Border.Resources>
            <DockPanel>
                <!-- Controlli finestra -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Stretch">
                    <Button x:Name="MinBtn" Content="&#xE921;" Style="{StaticResource WinBtn}" Click="MinBtn_Click"
                            ToolTip="Riduci a icona"/>
                    <Button x:Name="MaxBtn" Content="&#xE922;" Style="{StaticResource WinBtn}" Click="MaxBtn_Click"
                            ToolTip="Ingrandisci / Ripristina"/>
                    <Button x:Name="CloseBtn" Content="&#xE8BB;" Style="{StaticResource WinCloseBtn}" Click="CloseBtn_Click"
                            ToolTip="Chiudi"/>
                </StackPanel>

                <!-- Utente -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="#BFD6EC" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="BrandUser" FontSize="12" Foreground="#E3EEF8" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Brand + breadcrumb -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                    <Border x:Name="BrandLogo" Background="Transparent" Margin="0,0,8,0" Cursor="Hand"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            MouseLeftButtonDown="BrandLogo_MouseLeftButtonDown"
                            ToolTip="KBM">
                        <TextBlock Text="&#xE821;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="KBM" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="ERP" FontSize="13" Foreground="#9FC2E2" Margin="3,0,0,0" VerticalAlignment="Center"/>
                    <Border Width="1" Height="16" Background="#3D6EA0" Margin="14,0"/>
                    <TextBlock x:Name="BreadcrumbIcon" Text="&#xE80F;" FontFamily="Segoe MDL2 Assets"
                               FontSize="14" Foreground="White" Margin="0,0,9,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="Breadcrumb" Text="Dashboard" FontSize="13" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===================== BODY ===================== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Menu ad albero (nav pane stile Mago/Ad Hoc) -->
            <Border Grid.Column="0" Background="{StaticResource Brush.NavBg}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{StaticResource Brush.NavHeader}" Padding="12,7">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE700;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="MENU FUNZIONI" FontSize="11" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <!-- Ricerca modulo per nome o codice (stile NTS: digita e INVIO) -->
                    <Border DockPanel.Dock="Top" Background="{StaticResource Brush.NavBg}"
                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1" Padding="6,6">
                        <Grid>
                            <TextBox x:Name="NavSearchBox" Height="28" Padding="26,0,22,0" FontSize="12"
                                     VerticalContentAlignment="Center"
                                     Tag="Cerca modulo o codice (es. ANACL)"
                                     TextChanged="NavSearchBox_TextChanged" PreviewKeyDown="NavSearchBox_PreviewKeyDown"/>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{StaticResource Brush.TextMuted}" IsHitTestVisible="False"
                                       Margin="8,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <Button x:Name="NavSearchClear" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                    FontSize="10" Width="20" Height="20" Padding="0" Margin="0,0,3,0"
                                    HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent"
                                    BorderThickness="0" Cursor="Hand" Visibility="Collapsed"
                                    Foreground="{StaticResource Brush.TextMuted}"
                                    Click="NavSearchClear_Click" ToolTip="Pulisci ricerca"/>
                        </Grid>
                    </Border>
                    <!-- Albero popolato da NavigationRegistry (BuildNavTree) -->
                    <TreeView x:Name="NavTree" BorderThickness="0" Background="Transparent"
                              SelectedItemChanged="NavTree_SelectedItemChanged" Padding="2,6"/>
                </DockPanel>
            </Border>

            <!-- Area documenti multi-tab -->
            <Grid Grid.Column="1" Background="{StaticResource Brush.AppBg}">
                <TabControl x:Name="DocTabs" Margin="0"
                            Style="{StaticResource KbmDocTabControl}"
                            ItemContainerStyle="{StaticResource KbmDocTabItem}"
                            ItemTemplate="{StaticResource KbmDocTabHeader}">
                    <TabControl.ContentTemplate>
                        <DataTemplate>
                            <Border Background="White" BorderBrush="{StaticResource Brush.Border}"
                                    BorderThickness="0,1,0,0" Padding="20,16">
                                <ContentPresenter Content="{Binding Content}"/>
                            </Border>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>

                <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                               Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                    <TextBlock Text="Nessun documento aperto" Foreground="#9CA3AF" FontSize="14"
                               Margin="0,12,0,0" HorizontalAlignment="Center"/>
                    <TextBlock Text="Seleziona una funzione dal menu a sinistra" Foreground="#9CA3AF"
                               FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ===================== STATUS BAR ===================== -->
        <Border Grid.Row="3" Background="{StaticResource Brush.TopBar}">
            <DockPanel Margin="12,0">
                <TextBlock x:Name="StatusText" FontSize="11" Foreground="#CBD5E1" VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#22C55E" Margin="0,0,6,0"/>
                    <TextBlock Text="API connessa" FontSize="11" Foreground="#CBD5E1"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===================== MESSAGGI POPUP (toast, stile Business Cube) ===================== -->
        <ItemsControl x:Name="ToastHost" Grid.RowSpan="4" Panel.ZIndex="999"
                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,16,34"
                      IsHitTestVisible="True"/>
    </Grid>
</Window>
