<Window x:Class="KBM.Client.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="KBM — Accesso" Height="468" Width="760"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" Background="{StaticResource Brush.AppBg}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="42" ResizeBorderThickness="0" CornerRadius="0"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{StaticResource Brush.AppBg}" BorderBrush="{StaticResource Brush.Primary}" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="288"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Pannello brand -->
            <Border Grid.Column="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{StaticResource C.Primary600}" Offset="0"/>
                        <GradientStop Color="{StaticResource C.Primary700}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="28">
                    <StackPanel VerticalAlignment="Top">
                        <TextBlock Text="&#xE821;" FontFamily="Segoe MDL2 Assets" FontSize="34" Foreground="White"/>
                        <TextBlock Margin="0,14,0,0">
                            <Run Text="KBM" FontSize="30" FontWeight="Bold" Foreground="White"/>
                            <Run Text="ERP" FontSize="30" Foreground="#9FC2E2"/>
                        </TextBlock>
                        <TextBlock Text="Kever Business Manager" FontSize="13" Foreground="#CFE0F0" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Bottom">
                        <Border Height="1" Background="#3D6EA0" Margin="0,0,0,12"/>
                        <TextBlock Text="Gestionale enterprise modulare" FontSize="11" Foreground="#BFD6EC"/>
                        <TextBlock Text="© Kever — tutti i diritti riservati" FontSize="10" Foreground="#8FB2D4" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Pannello form -->
            <Grid Grid.Column="1">
                <!-- Pulsante chiudi -->
                <Button x:Name="CloseBtn" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                        Width="42" Height="32" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Background="Transparent" BorderThickness="0" Foreground="{StaticResource Brush.TextSecondary}"
                        Click="Close_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="Chiudi"/>

                <StackPanel Margin="40,52,40,40" VerticalAlignment="Center">
                    <TextBlock Text="Accesso" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}"/>
                    <TextBlock Text="Inserisci le tue credenziali per continuare" FontSize="12"
                               Foreground="{StaticResource Brush.TextSecondary}" Margin="0,2,0,22"/>

                    <TextBlock Text="Username" Margin="0,0,0,4" FontSize="12"/>
                    <TextBox x:Name="UsernameBox" Style="{StaticResource KbmTextBox}" Height="36" Margin="0,0,0,14"/>

                    <TextBlock Text="Password" Margin="0,0,0,4" FontSize="12"/>
                    <PasswordBox x:Name="PasswordBox" FontFamily="Segoe UI" FontSize="14" Padding="10,0"
                                 VerticalContentAlignment="Center" Height="36" Margin="0,0,0,8"/>

                    <TextBlock x:Name="ErrorText" Foreground="{StaticResource Brush.Error}" FontSize="12"
                               TextWrapping="Wrap" Visibility="Collapsed" Margin="0,2,0,0"/>

                    <Button Content="Accedi" Style="{StaticResource KbmButton}" Height="40" Margin="0,18,0,0"
                            Click="Login_Click" IsDefault="True"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
