<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================================
         KBM Design Tokens — derivati da docs/ux/style-guide.md
         ============================================================ -->

    <!-- Primary (corporate steel-blue, look gestionale enterprise) -->
    <Color x:Key="C.Primary50">#EAF1F8</Color>
    <Color x:Key="C.Primary100">#D3E3F2</Color>
    <Color x:Key="C.Primary500">#1C5D99</Color>
    <Color x:Key="C.Primary600">#174E80</Color>
    <Color x:Key="C.Primary700">#123E66</Color>
    <Color x:Key="C.Primary900">#0E3350</Color>

    <!-- Semantic -->
    <Color x:Key="C.Success500">#10B981</Color>
    <Color x:Key="C.Success700">#047857</Color>
    <Color x:Key="C.Warning500">#F59E0B</Color>
    <Color x:Key="C.Error500">#EF4444</Color>
    <Color x:Key="C.Error700">#B91C1C</Color>
    <Color x:Key="C.Info500">#06B6D4</Color>

    <!-- Neutral -->
    <Color x:Key="C.Gray50">#F9FAFB</Color>
    <Color x:Key="C.Gray100">#F3F4F6</Color>
    <Color x:Key="C.Gray200">#E5E7EB</Color>
    <Color x:Key="C.Gray300">#D1D5DB</Color>
    <Color x:Key="C.Gray400">#9CA3AF</Color>
    <Color x:Key="C.Gray500">#6B7280</Color>
    <Color x:Key="C.Gray700">#374151</Color>
    <Color x:Key="C.Gray900">#111827</Color>

    <!-- Structural (bande cromatiche corporate) -->
    <Color x:Key="C.TopBar">#15456B</Color>
    <Color x:Key="C.TopBarDeep">#0E3350</Color>
    <Color x:Key="C.SideNav">#0F172A</Color>
    <Color x:Key="C.SideNavHover">#1E293B</Color>
    <Color x:Key="C.SideNavActive">#1C5D99</Color>

    <!-- Nav pane chiaro (stile Mago/Ad Hoc) -->
    <Color x:Key="C.NavBg">#ECF1F6</Color>
    <Color x:Key="C.NavHeader">#2A4A6B</Color>
    <Color x:Key="C.NavHover">#DCE6F1</Color>

    <!-- ============ Brushes ============ -->
    <SolidColorBrush x:Key="Brush.Primary" Color="{StaticResource C.Primary500}"/>
    <SolidColorBrush x:Key="Brush.PrimaryHover" Color="{StaticResource C.Primary600}"/>
    <SolidColorBrush x:Key="Brush.PrimaryActive" Color="{StaticResource C.Primary700}"/>
    <SolidColorBrush x:Key="Brush.PrimarySoft" Color="{StaticResource C.Primary50}"/>
    <SolidColorBrush x:Key="Brush.PrimarySelect" Color="{StaticResource C.Primary100}"/>

    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource C.Success500}"/>
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource C.Warning500}"/>
    <SolidColorBrush x:Key="Brush.Error" Color="{StaticResource C.Error500}"/>
    <SolidColorBrush x:Key="Brush.Info" Color="{StaticResource C.Info500}"/>

    <SolidColorBrush x:Key="Brush.AppBg" Color="#E7ECF2"/>
    <SolidColorBrush x:Key="Brush.Surface" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="{StaticResource C.Gray50}"/>
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource C.Gray200}"/>
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="{StaticResource C.Gray300}"/>

    <SolidColorBrush x:Key="Brush.Text" Color="{StaticResource C.Gray900}"/>
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource C.Gray500}"/>
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource C.Gray400}"/>
    <SolidColorBrush x:Key="Brush.TextOnDark" Color="#F1F5F9"/>

    <SolidColorBrush x:Key="Brush.TopBar" Color="{StaticResource C.TopBar}"/>
    <SolidColorBrush x:Key="Brush.SideNav" Color="{StaticResource C.SideNav}"/>
    <SolidColorBrush x:Key="Brush.SideNavHover" Color="{StaticResource C.SideNavHover}"/>
    <SolidColorBrush x:Key="Brush.SideNavActive" Color="{StaticResource C.SideNavActive}"/>
    <SolidColorBrush x:Key="Brush.SideNavText" Color="#94A3B8"/>

    <SolidColorBrush x:Key="Brush.GridHeader" Color="#E4EBF2"/>
    <SolidColorBrush x:Key="Brush.GridZebra" Color="#F5F8FB"/>
    <SolidColorBrush x:Key="Brush.GridSelect" Color="{StaticResource C.Primary100}"/>

    <SolidColorBrush x:Key="Brush.NavBg" Color="{StaticResource C.NavBg}"/>
    <SolidColorBrush x:Key="Brush.NavHeader" Color="{StaticResource C.NavHeader}"/>
    <SolidColorBrush x:Key="Brush.NavHover" Color="{StaticResource C.NavHover}"/>

    <!-- Typography -->
    <FontFamily x:Key="Font.UI">Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Mono">Consolas</FontFamily>
    <!-- Densità enterprise (stile NTS Business Cube): font compatti, righe basse -->
    <sys:Double x:Key="Size.Body">12</sys:Double>
    <sys:Double x:Key="Size.Grid">11.5</sys:Double>
    <sys:Double x:Key="Size.Field">12</sys:Double>
    <sys:Double x:Key="Size.Caption">10.5</sys:Double>
    <sys:Double x:Key="Size.H1">19</sys:Double>
    <sys:Double x:Key="Size.H2">15</sys:Double>
    <sys:Double x:Key="Size.H3">13</sys:Double>

    <!-- Metriche compatte riutilizzabili -->
    <sys:Double x:Key="Metric.FieldHeight">26</sys:Double>
    <sys:Double x:Key="Metric.ButtonHeight">28</sys:Double>
    <sys:Double x:Key="Metric.RowHeight">24</sys:Double>
    <sys:Double x:Key="Metric.HeaderHeight">26</sys:Double>

    <CornerRadius x:Key="Radius.Sm">2</CornerRadius>
    <CornerRadius x:Key="Radius.Md">3</CornerRadius>
    <CornerRadius x:Key="Radius.Lg">4</CornerRadius>

</ResourceDictionary>
