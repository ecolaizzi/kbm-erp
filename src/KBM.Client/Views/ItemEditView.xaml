<UserControl x:Class="KBM.Client.Views.ItemEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}"/>
        </Style>
        <Style x:Key="SectionBand" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.NavHeader}"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="SectionBandText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="ColForm" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Brush.SurfaceAlt}" BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1" CornerRadius="3" Padding="10,6" Margin="0,0,0,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="SaveBtn" Style="{StaticResource KbmPrimary}" Height="28" Padding="14,0"
                            Margin="0,0,8,0" Click="Save_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Salva" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Content="Annulla" Height="28" Padding="14,0" Click="Cancel_Click"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock x:Name="FormTitle" Text="Nuovo articolo" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.Text}"/>
                    <TextBlock x:Name="FormSubtitle" Text="Compila i dati e premi Salva" FontSize="11"
                               Foreground="{StaticResource Brush.TextSecondary}" Margin="0,1,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border x:Name="ErrorBox" Grid.Row="1" Visibility="Collapsed" Margin="0,0,0,8"
                Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="3" Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                           Foreground="{StaticResource Brush.Error}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="ErrorText" Foreground="#991B1B" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,2,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource SectionBand}"><TextBlock Text="DATI PRINCIPALI" Style="{StaticResource SectionBandText}"/></Border>
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Style="{StaticResource ColForm}">
                            <TextBlock Text="Codice *" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="CodeBox"/>
                        </StackPanel>
                        <StackPanel x:Name="StatusPanel" Grid.Column="2" Style="{StaticResource ColForm}" Visibility="Collapsed">
                            <TextBlock Text="Stato" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="StatusCombo">
                                <ComboBoxItem Content="Attivo" Tag="Active" IsSelected="True"/>
                                <ComboBoxItem Content="Disattivato" Tag="Inactive"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                    <StackPanel Style="{StaticResource ColForm}">
                        <TextBlock Text="Descrizione *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="DescriptionBox"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Style="{StaticResource ColForm}">
                            <TextBlock Text="Categoria" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CategoryCombo" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Style="{StaticResource ColForm}">
                            <TextBlock Text="Unit\u00e0 di misura" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="UmBox" Text="NR" MaxLength="10"/>
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource SectionBand}" Margin="0,8,0,8"><TextBlock Text="CODICI" Style="{StaticResource SectionBandText}"/></Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Style="{StaticResource ColForm}">
                            <TextBlock Text="Barcode (EAN)" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="BarcodeBox" MaxLength="30"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Style="{StaticResource ColForm}">
                            <TextBlock Text="Codice fornitore" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="SupplierCodeBox" MaxLength="50"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource SectionBand}"><TextBlock Text="DATI COMMERCIALI" Style="{StaticResource SectionBandText}"/></Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Style="{StaticResource ColForm}">
                            <TextBlock Text="Prezzo base" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="PriceBox" Text="0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Style="{StaticResource ColForm}">
                            <TextBlock Text="Aliquota IVA %" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="VatBox" Text="22"/>
                        </StackPanel>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Style="{StaticResource ColForm}">
                            <TextBlock Text="Conto ricavi" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="RevenueBox" MaxLength="50"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Style="{StaticResource ColForm}">
                            <TextBlock Text="Conto costi" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="CostBox" MaxLength="50"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Style="{StaticResource ColForm}">
                        <TextBlock Text="Note" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="NotesBox" Height="56" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
