<UserControl x:Class="KBM.Client.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock x:Name="WelcomeText" FontSize="{StaticResource Size.H1}" FontWeight="Bold"
                       Foreground="{StaticResource Brush.Text}" Margin="0,0,0,4"/>
            <TextBlock x:Name="DateText" FontSize="13" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,24"/>

            <UniformGrid Columns="4" Margin="0,0,0,28">
                <Border Background="White" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                        CornerRadius="8" Padding="18,16" Margin="0,0,14,0">
                    <DockPanel>
                        <Border DockPanel.Dock="Right" Width="42" Height="42" CornerRadius="8"
                                Background="{StaticResource Brush.PrimarySoft}" VerticalAlignment="Top">
                            <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource Brush.Primary}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="UTENTI" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" FontWeight="SemiBold"/>
                            <TextBlock x:Name="KpiUsers" Text="—" FontSize="30" FontWeight="Bold" Margin="0,6,0,0"
                                       Foreground="{StaticResource Brush.Text}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
                <Border Background="White" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                        CornerRadius="8" Padding="18,16" Margin="0,0,14,0">
                    <DockPanel>
                        <Border DockPanel.Dock="Right" Width="42" Height="42" CornerRadius="8"
                                Background="#ECFDF5" VerticalAlignment="Top">
                            <TextBlock Text="&#xE821;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource Brush.Success}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="AZIENDE" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" FontWeight="SemiBold"/>
                            <TextBlock x:Name="KpiCompanies" Text="—" FontSize="30" FontWeight="Bold" Margin="0,6,0,0"
                                       Foreground="{StaticResource Brush.Text}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
                <Border Background="White" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                        CornerRadius="8" Padding="18,16" Margin="0,0,14,0" Opacity="0.55">
                    <DockPanel>
                        <Border DockPanel.Dock="Right" Width="42" Height="42" CornerRadius="8"
                                Background="{StaticResource Brush.SurfaceAlt}" VerticalAlignment="Top">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource Brush.TextMuted}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="CLIENTI" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" FontWeight="SemiBold"/>
                            <TextBlock Text="W3" FontSize="30" FontWeight="Bold" Margin="0,6,0,0" Foreground="{StaticResource Brush.TextMuted}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
                <Border Background="White" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                        CornerRadius="8" Padding="18,16" Opacity="0.55">
                    <DockPanel>
                        <Border DockPanel.Dock="Right" Width="42" Height="42" CornerRadius="8"
                                Background="{StaticResource Brush.SurfaceAlt}" VerticalAlignment="Top">
                            <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                       Foreground="{StaticResource Brush.TextMuted}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="ARTICOLI" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" FontWeight="SemiBold"/>
                            <TextBlock Text="W4" FontSize="30" FontWeight="Bold" Margin="0,6,0,0" Foreground="{StaticResource Brush.TextMuted}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </UniformGrid>

            <TextBlock Text="Azioni rapide" FontSize="{StaticResource Size.H3}" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.Text}" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
                <Button Content="Gestione utenti" Style="{StaticResource KbmToolbarButton}" Click="GoUsers_Click"/>
                <Button Content="Gestione aziende" Style="{StaticResource KbmToolbarButton}" Click="GoCompanies_Click"/>
                <Button Content="Ruoli e permessi" Style="{StaticResource KbmToolbarButton}" Click="GoRoles_Click"/>
            </StackPanel>

            <TextBlock Text="Sessione corrente" FontSize="{StaticResource Size.H3}" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.Text}" Margin="0,0,0,10"/>
            <Border Background="White" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                    CornerRadius="8" Padding="18" MaxWidth="520" HorizontalAlignment="Left">
                <TextBlock x:Name="SessionInfo" FontSize="13" Foreground="{StaticResource Brush.Text}"
                           TextWrapping="Wrap" LineHeight="22"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
