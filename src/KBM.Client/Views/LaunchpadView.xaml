<UserControl x:Class="KBM.Client.Views.LaunchpadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock x:Name="Greeting" FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.Text}"/>
            <TextBlock x:Name="SubGreeting" FontSize="12" Foreground="{StaticResource Brush.TextSecondary}"
                       Margin="0,2,0,0"/>
            <Border Height="1" Background="{StaticResource Brush.Border}" Margin="0,16,0,20"/>
            <StackPanel x:Name="Sections"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
