<UserControl x:Class="KBM.Client.Views.ChartAccountEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}"/>
        </Style>
        <Style x:Key="SectionBand" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.NavHeader}"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="SectionBandText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="ColForm" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Brush.SurfaceAlt}" BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1" CornerRadius="3" Padding="10,6" Margin="0,0,0,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="SaveBtn" Style="{StaticResource KbmPrimary}" Height="28" Padding="14,0"
                            Margin="0,0,8,0" Click="Save_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Salva" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Content="Annulla" Height="28" Padding="14,0" Click="Cancel_Click"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock x:Name="FormTitle" Text="Nuovo conto" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.Text}"/>
                    <TextBlock x:Name="FormSubtitle" Text="Sistema dei mastri \u00b7 compila i dati e premi Salva" FontSize="11"
                               Foreground="{StaticResource Brush.TextSecondary}" Margin="0,1,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border x:Name="ErrorBox" Grid.Row="1" Visibility="Collapsed" Margin="0,0,0,8"
                Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="3" Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                           Foreground="{StaticResource Brush.Error}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="ErrorText" Foreground="#991B1B" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,2,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource SectionBand}"><TextBlock Text="POSIZIONE GERARCHICA" Style="{StaticResource SectionBandText}"/></Border>
                    <StackPanel Style="{StaticResource ColForm}">
                        <TextBlock Text="Voce padre" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="ParentCombo" DisplayMemberPath="Display" SelectionChanged="Parent_Changed"/>
                        <TextBlock x:Name="ParentHint" FontSize="10.5" Margin="0,3,0,0"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   Text="Nessun padre = Mastro (1\u00b0 livello)"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Style="{StaticResource ColForm}">
                            <TextBlock Text="Codice segmento *" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="CodeBox" MaxLength="20" TextChanged="Recalc"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Style="{StaticResource ColForm}">
                            <TextBlock Text="Codice completo" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="FullCodeBox" IsReadOnly="True" Background="{StaticResource Brush.SurfaceAlt}"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Style="{StaticResource ColForm}">
                        <TextBlock Text="Descrizione *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="NameBox" MaxLength="150"/>
                    </StackPanel>
                    <StackPanel x:Name="StatusPanel" Style="{StaticResource ColForm}" Visibility="Collapsed">
                        <TextBlock Text="Stato" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="StatusCombo">
                            <ComboBoxItem Content="Attivo" Tag="Active" IsSelected="True"/>
                            <ComboBoxItem Content="Disattivato" Tag="Inactive"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource SectionBand}"><TextBlock Text="CLASSIFICAZIONE CONTABILE" Style="{StaticResource SectionBandText}"/></Border>
                    <StackPanel Style="{StaticResource ColForm}">
                        <TextBlock Text="Natura" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="NatureCombo">
                            <ComboBoxItem Content="Patrimoniale" Tag="1" IsSelected="True"/>
                            <ComboBoxItem Content="Economico" Tag="2"/>
                            <ComboBoxItem Content="Conto d'ordine" Tag="3"/>
                        </ComboBox>
                        <TextBlock x:Name="NatureHint" FontSize="10.5" Margin="0,3,0,0"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   Text="Definita sul mastro, ereditata a cascata"/>
                    </StackPanel>
                    <StackPanel Style="{StaticResource ColForm}">
                        <TextBlock Text="Segno (Dare/Avere)" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="SignCombo">
                            <ComboBoxItem Content="Dare (attivo / costo)" Tag="1" IsSelected="True"/>
                            <ComboBoxItem Content="Avere (passivo / ricavo)" Tag="2"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Style="{StaticResource ColForm}">
                        <TextBlock Text="Tipo conto" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="SubKindCombo">
                            <ComboBoxItem Content="Standard" Tag="0" IsSelected="True"/>
                            <ComboBoxItem Content="Cliente" Tag="1"/>
                            <ComboBoxItem Content="Fornitore" Tag="2"/>
                            <ComboBoxItem Content="Banca" Tag="3"/>
                            <ComboBoxItem Content="Cassa" Tag="4"/>
                            <ComboBoxItem Content="IVA" Tag="5"/>
                            <ComboBoxItem Content="Ritenuta" Tag="6"/>
                        </ComboBox>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Style="{StaticResource ColForm}">
                            <TextBlock Text="Bil. CEE dare" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="CeeDareBox" MaxLength="20"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Style="{StaticResource ColForm}">
                            <TextBlock Text="Bil. CEE avere" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="CeeAvereBox" MaxLength="20"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
