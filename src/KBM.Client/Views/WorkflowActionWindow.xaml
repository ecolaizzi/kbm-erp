<Window x:Class="KBM.Client.Views.WorkflowActionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Azione workflow" Height="280" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource Brush.Surface}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" x:Name="TitleText" Text="Completa task" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,2"/>
        <TextBlock Grid.Row="1" x:Name="SubtitleText" Text="" FontSize="11"
                   Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,12" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="2" x:Name="DecisionPanel" Visibility="Collapsed" Margin="0,0,0,10">
            <TextBlock Text="Esito" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,3"/>
            <ComboBox x:Name="DecisionCombo" Height="28"/>
        </StackPanel>

        <StackPanel Grid.Row="3">
            <TextBlock Text="Note" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,3"/>
            <TextBox x:Name="NotesBox" AcceptsReturn="True" TextWrapping="Wrap" Height="70" VerticalContentAlignment="Top"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="OkBtn" Content="Conferma" Style="{StaticResource KbmPrimary}" Height="28" Padding="16,0" Margin="0,0,8,0" Click="Ok_Click"/>
            <Button Content="Annulla" Height="28" Padding="16,0" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
