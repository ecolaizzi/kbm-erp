<UserControl x:Class="KBM.Client.Views.RfqEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}"/>
        </Style>
        <Style x:Key="SectionBand" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.NavHeader}"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="SectionBandText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Brush.SurfaceAlt}" BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1" CornerRadius="3" Padding="10,6" Margin="0,0,0,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="SaveBtn" Style="{StaticResource KbmPrimary}" Height="28" Padding="14,0" Margin="0,0,8,0" Click="Save_Click" ToolTip="Salva (F9)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Salva" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="PrintBtn" Height="28" Padding="14,0" Margin="0,0,8,0" Click="Print_Click" ToolTip="Stampa (F6)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Stampa" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Content="Annulla" Height="28" Padding="14,0" Click="Cancel_Click" ToolTip="Esci (ESC)"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock x:Name="FormTitle" Text="Nuova richiesta di offerta" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}"/>
                    <TextBlock x:Name="FormSubtitle" Text="Seleziona il fornitore, compila le righe e premi Salva" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,1,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border x:Name="ErrorBox" Grid.Row="1" Visibility="Collapsed" Margin="0,0,0,8"
                Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="3" Padding="10,6">
            <TextBlock x:Name="ErrorText" Foreground="#991B1B" FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Data" Style="{StaticResource FieldLabel}"/>
                    <DatePicker x:Name="DateBox"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Fornitore" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="SupplierCombo" DisplayMemberPath="BusinessName" SelectedValuePath="Id"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Scadenza risposta" Style="{StaticResource FieldLabel}"/>
                    <DatePicker x:Name="DueDateBox"/>
                </StackPanel>
                <StackPanel Grid.Column="6">
                    <TextBlock Text="Stato" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="StatusBox"/>
                </StackPanel>
            </Grid>
        </Border>

        <DockPanel Grid.Row="3">
            <Border DockPanel.Dock="Top" Style="{StaticResource SectionBand}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button x:Name="PersoBtn" Content="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                Height="22" Width="26" Padding="0" Margin="0,0,6,0" Click="Personalize_Click"
                                ToolTip="Layout corpo / personalizzazione colonne"/>
                        <Button x:Name="FromItemBtn" Content="Da articolo" Height="22" Padding="10,0" Margin="0,0,6,0" Click="FromItem_Click"/>
                        <Button x:Name="AddLineBtn" Content="+ Riga" Height="22" Padding="10,0" Margin="0,0,6,0" Click="AddLine_Click"/>
                        <Button x:Name="RemoveLineBtn" Content="- Riga" Height="22" Padding="10,0" Click="RemoveLine_Click"/>
                    </StackPanel>
                    <TextBlock Text="RIGHE / QUOTAZIONI" Style="{StaticResource SectionBandText}" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
            <Border DockPanel.Dock="Bottom" Background="{StaticResource Brush.SurfaceAlt}" BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1" CornerRadius="3" Padding="10,5" Margin="0,8,0,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <TextBlock Text="Totale imponibile:" FontSize="12" Foreground="{StaticResource Brush.TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TotalText" Text="0,00" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="LineCountText" Text="0 righe" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
            <ContentControl x:Name="LinesHost"/>
        </DockPanel>
    </Grid>
</UserControl>
