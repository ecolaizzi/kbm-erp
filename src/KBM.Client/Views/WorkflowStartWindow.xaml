<Window x:Class="KBM.Client.Views.WorkflowStartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Avvia processo" Height="330" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource Brush.Surface}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Avvia un nuovo processo" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,2"/>
        <TextBlock Grid.Row="1" Text="Seleziona il modello attivo e (opzionale) l'oggetto gestionale collegato." FontSize="11"
                   Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,12" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock Text="Modello *" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,3"/>
            <ComboBox x:Name="DefinitionCombo" Height="28" DisplayMemberPath="Name" SelectedValuePath="Id"/>
        </StackPanel>
        <StackPanel Grid.Row="3" Margin="0,0,0,8">
            <TextBlock Text="Titolo processo" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,3"/>
            <TextBox x:Name="TitleBox"/>
        </StackPanel>
        <Grid Grid.Row="4" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Oggetto collegato" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,3"/>
                <ComboBox x:Name="LinkTypeCombo" Height="28">
                    <ComboBoxItem Content="(nessuno)" Tag="" IsSelected="True"/>
                    <ComboBoxItem Content="Richiesta di acquisto (RDA)" Tag="purchase-request"/>
                    <ComboBoxItem Content="Richiesta di offerta (RDO)" Tag="rfq"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="ID oggetto" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,3"/>
                <TextBox x:Name="LinkIdBox"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Avvia" Style="{StaticResource KbmPrimary}" Height="28" Padding="16,0" Margin="0,0,8,0" Click="Ok_Click"/>
            <Button Content="Annulla" Height="28" Padding="16,0" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
