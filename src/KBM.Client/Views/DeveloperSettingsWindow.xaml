<Window x:Class="KBM.Client.Views.DeveloperSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modalita sviluppatore - Configurazioni" Height="640" Width="980"
        WindowStartupLocation="CenterOwner" Background="{StaticResource Brush.Surface}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Brush.NavHeader}" Padding="14,9">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Modalita sviluppatore" FontSize="15" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="ContextText" FontSize="11" Foreground="#CFE0F0" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <Border x:Name="ErrorBox" Grid.Row="1" Visibility="Collapsed" Margin="14,10,14,0"
                Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="3" Padding="10,6">
            <TextBlock x:Name="ErrorText" Foreground="#991B1B" FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <TabControl Grid.Row="2" Margin="14" Background="Transparent" BorderThickness="0">
            <!-- Report e motori di stampa -->
            <TabItem Header="Report e motori di stampa">
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <DockPanel Grid.Column="0">
                        <TextBlock DockPanel.Dock="Top" Text="REPORT CONFIGURATI" FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,6"/>
                        <ListBox x:Name="ReportList" SelectionChanged="ReportList_SelectionChanged"
                                 DisplayMemberPath="Display"/>
                    </DockPanel>

                    <StackPanel Grid.Column="2" x:Name="ReportForm" IsEnabled="False">
                        <TextBlock Text="Chiave report" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,3"/>
                        <TextBox x:Name="RepKeyBox" IsEnabled="False" Margin="0,0,0,8"/>
                        <TextBlock Text="Titolo" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,3"/>
                        <TextBox x:Name="RepTitleBox" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Motore di stampa" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,3"/>
                                <ComboBox x:Name="RepEngineCombo">
                                    <ComboBoxItem Content="QuestPDF (moderno)" Tag="0"/>
                                    <ComboBoxItem Content="Stampa unione Word" Tag="1"/>
                                    <ComboBoxItem Content="Crystal Reports (non attivo)" Tag="2"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Formato" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,3"/>
                                <ComboBox x:Name="RepFormatCombo">
                                    <ComboBoxItem Content="PDF" Tag="0"/>
                                    <ComboBoxItem Content="DOCX" Tag="1"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Percorso / nome template (per stampa unione / Crystal)" FontSize="11"
                                   Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,3"/>
                        <TextBox x:Name="RepTemplateBox" Margin="0,0,0,8"/>
                        <CheckBox x:Name="RepEnabledCheck" Content="Abilitato" Margin="0,0,0,12"/>
                        <Button x:Name="RepSaveBtn" Content="Salva report" Style="{StaticResource KbmPrimary}"
                                Height="28" Padding="14,0" HorizontalAlignment="Left" Click="SaveReport_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Configurazione azienda -->
            <TabItem Header="Configurazione azienda">
                <DockPanel Margin="0,8,0,0">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="+ Aggiungi" Height="26" Padding="10,0" Margin="0,0,6,0" Click="AddCompanySetting_Click"/>
                        <Button Content="Salva modifiche" Height="26" Padding="10,0" Margin="0,0,6,0" Click="SaveCompanySettings_Click"/>
                        <Button Content="Aggiorna" Height="26" Padding="10,0" Click="ReloadCompany_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="CompanyGrid" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Chiave" Binding="{Binding Key}" Width="220"/>
                            <DataGridTextColumn Header="Valore" Binding="{Binding Value}" Width="*"/>
                            <DataGridTextColumn Header="Categoria" Binding="{Binding Category}" Width="140"/>
                            <DataGridTextColumn Header="Descrizione" Binding="{Binding Description}" Width="220"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- Impostazioni tecniche globali -->
            <TabItem Header="Impostazioni tecniche">
                <DockPanel Margin="0,8,0,0">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="+ Aggiungi" Height="26" Padding="10,0" Margin="0,0,6,0" Click="AddTechSetting_Click"/>
                        <Button Content="Salva modifiche" Height="26" Padding="10,0" Margin="0,0,6,0" Click="SaveTechSettings_Click"/>
                        <Button Content="Aggiorna" Height="26" Padding="10,0" Click="ReloadTech_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="TechGrid" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Chiave" Binding="{Binding Key}" Width="240"/>
                            <DataGridTextColumn Header="Valore" Binding="{Binding Value}" Width="*"/>
                            <DataGridTextColumn Header="Categoria" Binding="{Binding Category}" Width="140"/>
                            <DataGridTextColumn Header="Descrizione" Binding="{Binding Description}" Width="220"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- Stampa unione (help) -->
            <TabItem Header="Stampa unione">
                <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Stampa unione (Word)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,8"
                                   Text="Per usare la stampa unione, impostare il motore del report su 'Stampa unione Word' e indicare il percorso di un modello .docx. Nel modello sono supportati i seguenti segnaposto:"/>
                        <TextBlock FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"
                                   Text="{}{{Title}}  {{Subtitle}}  {{CompanyName}}  {{Footer}}  {{Campo:Etichetta}}  {{Lines}}"/>
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Brush.TextSecondary}" Margin="0,10,0,0"
                                   Text="{}{{Campo:Etichetta}} viene sostituito con il valore del campo di testata corrispondente; {{Lines}} con le righe del documento (tabulate)."/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
