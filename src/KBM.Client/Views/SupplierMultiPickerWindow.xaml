<Window x:Class="KBM.Client.Views.SupplierMultiPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fornitori da interpellare" Height="480" Width="560"
        WindowStartupLocation="CenterOwner" Background="{StaticResource Brush.Surface}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="HeaderText" Text="Fornitori candidati per la riga" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,2"/>
        <TextBlock Grid.Row="1" Text="Spunta i fornitori a cui inviare la richiesta di offerta per questa riga." FontSize="11"
                   Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,10"/>

        <Border Grid.Row="2" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="3">
            <ListBox x:Name="List" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding Selected, Mode=TwoWay}" Margin="4,3">
                            <TextBlock>
                                <Run Text="{Binding Code}" FontWeight="SemiBold"/>
                                <Run Text=" - "/>
                                <Run Text="{Binding BusinessName}"/>
                            </TextBlock>
                        </CheckBox>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Conferma" Style="{StaticResource KbmPrimary}" Height="28" Padding="16,0" Margin="0,0,8,0" Click="Ok_Click"/>
            <Button Content="Annulla" Height="28" Padding="16,0" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
