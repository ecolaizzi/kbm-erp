<UserControl x:Class="KBM.Client.Views.UserEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="FormTitle" Text="Nuovo utente" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.Text}"/>
            <TextBlock x:Name="FormSubtitle" Text="Compila i campi e premi Salva" FontSize="12"
                       Foreground="{StaticResource Brush.TextSecondary}" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Error banner -->
        <Border x:Name="ErrorBox" Grid.Row="1" Visibility="Collapsed" Margin="0,0,0,12"
                Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="3" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                           Foreground="{StaticResource Brush.Error}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="ErrorText" Foreground="#991B1B" FontSize="12" VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="760" HorizontalAlignment="Left">

                <!-- Dati anagrafici -->
                <TextBlock Text="DATI ANAGRAFICI" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,8"/>
                <Border Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1" CornerRadius="3" Padding="16" Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Username *" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox x:Name="UsernameBox" Height="32"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="Email *" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox x:Name="EmailBox" Height="32"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Nome" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox x:Name="FirstNameBox" Height="32"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="Cognome" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox x:Name="LastNameBox" Height="32"/>
                        </StackPanel>

                        <StackPanel x:Name="PasswordPanel" Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Password *" FontSize="12" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="PasswordBox" Height="32"/>
                        </StackPanel>
                        <StackPanel x:Name="StatusPanel" Grid.Row="2" Grid.Column="2" Visibility="Collapsed">
                            <TextBlock Text="Stato" FontSize="12" Margin="0,0,0,4"/>
                            <ComboBox x:Name="StatusCombo" Height="32">
                                <ComboBoxItem Content="Attivo" Tag="Active" IsSelected="True"/>
                                <ComboBoxItem Content="Disabilitato" Tag="Disabled"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="RUOLI" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,8"/>
                        <Border Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1" CornerRadius="3" Padding="14,10" MinHeight="120">
                            <ItemsControl x:Name="RolesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Label}" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Margin="0,3"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="AZIENDE" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,8"/>
                        <Border Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1" CornerRadius="3" Padding="14,10" MinHeight="120">
                            <ItemsControl x:Name="CompaniesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Label}" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Margin="0,3"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="3" BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,1,0,0"
                Margin="0,16,0,0" Padding="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelBtn" Content="Annulla" Width="110" Height="34" Margin="0,0,10,0"
                        Click="Cancel_Click"/>
                <Button x:Name="SaveBtn" Content="Salva" Width="130" Height="34"
                        Style="{StaticResource KbmPrimary}" Click="Save_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
