<UserControl x:Class="KBM.Client.Views.WorkflowDefinitionEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}"/>
        </Style>
        <Style x:Key="SectionBand" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.NavHeader}"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="SectionBandText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Brush.SurfaceAlt}" BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1" CornerRadius="3" Padding="10,6" Margin="0,0,0,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="SaveBtn" Style="{StaticResource KbmPrimary}" Height="28" Padding="14,0" Margin="0,0,8,0" Click="Save_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Salva" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Content="Annulla" Height="28" Padding="14,0" Click="Cancel_Click"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock x:Name="FormTitle" Text="Nuovo modello di workflow" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}"/>
                    <TextBlock x:Name="FormSubtitle" Text="Definisci gli step del processo e le relative azioni" FontSize="11"
                               Foreground="{StaticResource Brush.TextSecondary}" Margin="0,1,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border x:Name="ErrorBox" Grid.Row="1" Visibility="Collapsed" Margin="0,0,0,8"
                Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="3" Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource Brush.Error}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="ErrorText" Foreground="#991B1B" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Codice *" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="CodeBox" MaxLength="30"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Nome *" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="NameBox" MaxLength="150"/>
            </StackPanel>
            <StackPanel Grid.Column="4">
                <TextBlock Text="Stato" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="StatusCombo">
                    <ComboBoxItem Content="Bozza" Tag="Draft" IsSelected="True"/>
                    <ComboBoxItem Content="Attivo" Tag="Active"/>
                    <ComboBoxItem Content="Archiviato" Tag="Archived"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                <Border Style="{StaticResource SectionBand}" DockPanel.Dock="Left"><TextBlock Text="STEP DEL PROCESSO" Style="{StaticResource SectionBandText}"/></Border>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="+ Step" Height="26" Padding="10,0" Margin="0,0,6,0" Click="AddStep_Click"/>
                    <Button Content="- Rimuovi" Height="26" Padding="10,0" Click="RemoveStep_Click"/>
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1" x:Name="StepsHost" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"/>

            <Grid Grid.Row="2" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Campi configurabili (JSON)" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="FieldsBox" Height="60" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top"
                             FontFamily="Consolas" FontSize="11"/>
                    <TextBlock Text='Es: [{"Key":"importo","Label":"Importo","Type":"number","Required":true,"SetAtRuntime":true}]'
                               FontSize="10" Foreground="{StaticResource Brush.TextSecondary}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Legenda azioni / decisioni (per colonna nella griglia)" Style="{StaticResource FieldLabel}"/>
                    <TextBlock TextWrapping="Wrap" FontSize="10.5" Foreground="{StaticResource Brush.TextSecondary}">
                        <Run Text="Azioni (JSON): "/><Run FontFamily="Consolas" Text='[{"Type":"SetEntityStatus","Value":"Approvato"},{"Type":"Note","Value":"..."}]'/><LineBreak/>
                        <Run Text="Decisioni (JSON): "/><Run FontFamily="Consolas" Text='[{"Label":"Approva","Outcome":"Next"},{"Label":"Rifiuta","Outcome":"Reject"}]'/><LineBreak/>
                        <Run Text="Outcome ammessi: Next (avanza), Reject (riapre precedente), Complete (chiude processo)."/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
