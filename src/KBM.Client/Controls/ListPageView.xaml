<UserControl x:Class="KBM.Client.Controls.ListPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <Border DockPanel.Dock="Right" Style="{StaticResource KbmBadge}"
                    Background="{StaticResource Brush.PrimarySelect}" VerticalAlignment="Center">
                <TextBlock x:Name="CountText" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.PrimaryActive}"/>
            </Border>
            <StackPanel>
                <TextBlock x:Name="TitleText" FontSize="{StaticResource Size.H2}" FontWeight="Bold"
                           Foreground="{StaticResource Brush.Text}"/>
                <TextBlock x:Name="SubtitleText" FontSize="12" Foreground="{StaticResource Brush.TextSecondary}"
                           Margin="0,2,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </DockPanel>

        <!-- Command bar -->
        <Border Grid.Row="1" Background="{StaticResource Brush.SurfaceAlt}" BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1" CornerRadius="3" Padding="8,6" Margin="0,0,0,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Grid Width="240" Margin="0,0,8,0">
                        <TextBox x:Name="SearchBox" Tag="Cerca..." Height="32" Padding="32,0,10,0"/>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{StaticResource Brush.TextMuted}" IsHitTestVisible="False"
                                   Margin="11,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </Grid>
                    <StackPanel x:Name="LayoutPanel" Orientation="Horizontal" VerticalAlignment="Center"
                                Margin="0,0,8,0" Visibility="Collapsed">
                        <TextBlock Text="Layout" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"
                                   Foreground="{StaticResource Brush.TextSecondary}"/>
                        <ComboBox x:Name="LayoutCombo" Width="140" Height="32" VerticalContentAlignment="Center"
                                  SelectionChanged="LayoutCombo_SelectionChanged"
                                  ToolTip="Layout colonne (Layout corpo)"/>
                    </StackPanel>
                    <Button x:Name="PersonalizeBtn" Content="&#xE71D;" FontFamily="Segoe MDL2 Assets"
                            Width="32" Height="32" Padding="0" Margin="0,0,4,0" Visibility="Collapsed"
                            ToolTip="Personalizzazione griglie (colonne, larghezza, ordine)" Click="PersonalizeBtn_Click"/>
                    <Button x:Name="WingsToggle" Content="&#xE890;" FontFamily="Segoe MDL2 Assets"
                            Width="32" Height="32" Padding="0" Margin="0,0,4,0" ToolTip="Mostra/nascondi pannello dettaglio"
                            Click="WingsToggle_Click" Visibility="Collapsed"/>
                    <Button x:Name="ConfigBtn" Content="&#xE713;" FontFamily="Segoe MDL2 Assets"
                            Width="32" Height="32" Padding="0" ToolTip="Configura toolbar" Click="ConfigBtn_Click"/>
                    <Popup x:Name="ConfigPopup" PlacementTarget="{Binding ElementName=ConfigBtn}" Placement="Bottom"
                           StaysOpen="False" AllowsTransparency="True" HorizontalOffset="-160">
                        <Border Background="White" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                                CornerRadius="3" Padding="12" MinWidth="200">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="12" ShadowDepth="2"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Comandi visibili" FontWeight="SemiBold" FontSize="12"
                                           Foreground="{StaticResource Brush.TextSecondary}" Margin="0,0,0,8"/>
                                <StackPanel x:Name="ConfigList"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
                <StackPanel x:Name="ToolbarPanel" Orientation="Horizontal" DockPanel.Dock="Left"/>
                <StackPanel x:Name="FilterPanel" Orientation="Horizontal" HorizontalAlignment="Left"
                            Margin="12,0,0,0" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <TextBlock x:Name="ErrorText" Grid.Row="2" Foreground="{StaticResource Brush.Error}"
                   Margin="0,0,0,8" Visibility="Collapsed" FontSize="13"/>

        <!-- Work surface + Wings -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                    CornerRadius="3" ClipToBounds="True">
                <ContentPresenter x:Name="GridHost"/>
            </Border>

            <!-- Wings (pannello contestuale stile Business Cube) -->
            <Border x:Name="WingsPanel" Grid.Column="1" Width="300" Margin="12,0,0,0" Visibility="Collapsed"
                    Background="White" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="3">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{StaticResource Brush.SurfaceAlt}"
                            BorderBrush="{StaticResource Brush.Border}" BorderThickness="0,0,0,1" Padding="14,10">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                    Width="22" Height="22" Padding="0" FontSize="10" Background="Transparent"
                                    BorderThickness="0" ToolTip="Chiudi" Click="WingsToggle_Click"/>
                            <TextBlock x:Name="WingTitle" Text="Dettaglio" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{StaticResource Brush.Text}" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="WingHost" Margin="14,12">
                            <TextBlock x:Name="WingPlaceholder" Text="Seleziona un record per vederne il dettaglio."
                                       Foreground="{StaticResource Brush.TextMuted}" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Navigatore record (stile Business Cube: primo/prec  N/tot  succ/ultimo) -->
        <Border Grid.Row="4" Margin="0,10,0,0">
            <DockPanel>
                <TextBlock x:Name="PaginationText" FontSize="12" Foreground="{StaticResource Brush.TextSecondary}"
                           VerticalAlignment="Center"/>
                <StackPanel x:Name="RecordNav" Orientation="Horizontal" HorizontalAlignment="Right"
                            Visibility="Collapsed">
                    <Button x:Name="NavFirst" Content="&#xE892;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            Width="30" Height="28" Padding="0" Margin="0,0,3,0" Click="NavFirst_Click"
                            ToolTip="Primo record (Ctrl+P)"/>
                    <Button x:Name="NavPrev" Content="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            Width="30" Height="28" Padding="0" Margin="0,0,6,0" Click="NavPrev_Click"
                            ToolTip="Record precedente (Ctrl+R)"/>
                    <Border Background="{StaticResource Brush.SurfaceAlt}" BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1" CornerRadius="3" Padding="10,0" MinWidth="74" Height="28"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="NavPosText" Text="0 / 0" FontSize="12" FontWeight="SemiBold"
                                   TextAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource Brush.Text}"/>
                    </Border>
                    <Button x:Name="NavNext" Content="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            Width="30" Height="28" Padding="0" Margin="6,0,3,0" Click="NavNext_Click"
                            ToolTip="Record successivo (Ctrl+S)"/>
                    <Button x:Name="NavLast" Content="&#xE893;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            Width="30" Height="28" Padding="0" Click="NavLast_Click"
                            ToolTip="Ultimo record (Ctrl+U)"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
