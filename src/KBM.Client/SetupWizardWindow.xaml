<Window x:Class="KBM.Client.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="KBM - Configurazione iniziale" Height="560" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" Background="{StaticResource Brush.AppBg}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="42" ResizeBorderThickness="0" CornerRadius="0"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{StaticResource Brush.AppBg}" BorderBrush="{StaticResource Brush.Primary}" BorderThickness="1">
        <DockPanel>
            <!-- Caption corporate -->
            <Border DockPanel.Dock="Top" Height="42">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{StaticResource C.Primary600}" Offset="0"/>
                        <GradientStop Color="{StaticResource C.Primary700}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel Margin="14,0">
                    <Button DockPanel.Dock="Right" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                            Width="40" Height="42" Background="Transparent" BorderThickness="0" Foreground="White"
                            Click="Close_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="Chiudi"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE821;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White"
                                   Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="KBM" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text="ERP" FontSize="13" Foreground="#9FC2E2" Margin="3,0,0,0" VerticalAlignment="Center"/>
                        <Border Width="1" Height="16" Background="#3D6EA0" Margin="14,0"/>
                        <TextBlock Text="Configurazione iniziale" FontSize="13" FontWeight="SemiBold" Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>
            </Border>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Setup Wizard" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Brush.Primary}"/>
            <TextBlock x:Name="StepTitle" Text="Step 1 - Azienda" FontSize="14" Foreground="#6B7280"/>
        </StackPanel>

        <StackPanel x:Name="StepCompany" Grid.Row="1">
            <TextBlock Text="Codice azienda" Margin="0,0,0,4"/>
            <TextBox x:Name="CompanyCodeBox" Style="{StaticResource KbmTextBox}" Text="DEMO" Margin="0,0,0,10"/>
            <TextBlock Text="Ragione sociale" Margin="0,0,0,4"/>
            <TextBox x:Name="BusinessNameBox" Style="{StaticResource KbmTextBox}" Margin="0,0,0,10"/>
            <TextBlock Text="Partita IVA (opzionale)" Margin="0,0,0,4"/>
            <TextBox x:Name="VatBox" Style="{StaticResource KbmTextBox}"/>
        </StackPanel>

        <StackPanel x:Name="StepAdmin" Grid.Row="1" Visibility="Collapsed">
            <TextBlock Text="Username admin" Margin="0,0,0,4"/>
            <TextBox x:Name="AdminUserBox" Style="{StaticResource KbmTextBox}" Text="admin" Margin="0,0,0,10"/>
            <TextBlock Text="Email" Margin="0,0,0,4"/>
            <TextBox x:Name="AdminEmailBox" Style="{StaticResource KbmTextBox}" Text="admin@azienda.it" Margin="0,0,0,10"/>
            <TextBlock Text="Nome" Margin="0,0,0,4"/>
            <TextBox x:Name="FirstNameBox" Style="{StaticResource KbmTextBox}" Text="Mario" Margin="0,0,0,10"/>
            <TextBlock Text="Cognome" Margin="0,0,0,4"/>
            <TextBox x:Name="LastNameBox" Style="{StaticResource KbmTextBox}" Text="Rossi" Margin="0,0,0,10"/>
            <TextBlock Text="Password (min 8)" Margin="0,0,0,4"/>
            <PasswordBox x:Name="AdminPasswordBox" MinHeight="36" Padding="8,6"/>
        </StackPanel>

        <TextBlock x:Name="ErrorText" Grid.Row="1" VerticalAlignment="Bottom"
                   Foreground="{StaticResource Brush.Error}" TextWrapping="Wrap" Visibility="Collapsed"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BackBtn" Content="Indietro" Margin="0,0,8,0" Padding="12,8" Click="Back_Click" Visibility="Collapsed"/>
            <Button x:Name="NextBtn" Content="Avanti" Style="{StaticResource KbmButton}" Click="Next_Click"/>
        </StackPanel>
    </Grid>
        </DockPanel>
    </Border>
</Window>
